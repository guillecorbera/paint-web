# EmailJS Configuration
# Obtén estas credenciales en https://dashboard.emailjs.com/

# Public Key de EmailJS
VITE_EMAILJS_PUBLIC_KEY=tu_public_key_aqui

# Service ID (servicio de email configurado)
VITE_EMAILJS_SERVICE_ID=service_xxxxxxx

# Template ID para el email al negocio
VITE_EMAILJS_TEMPLATE_ID=template_xxxxxxx

# Template ID para el email de confirmación al usuario
VITE_EMAILJS_AUTORESPONSE_TEMPLATE_ID=template_autoresponse

# Email del negocio que recibirá los mensajes
VITE_CONTACT_TO_EMAIL=tu-email@dominio.com
